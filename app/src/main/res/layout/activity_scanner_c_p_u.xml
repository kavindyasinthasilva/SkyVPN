<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:paddingStart="20dp"
    android:paddingTop="18dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarr"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_glass_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back_black_24dp"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

    <LinearLayout
        android:id="@+id/cpu_title_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@id/toolbarr"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/toolbarr"
        app:layout_constraintTop_toTopOf="@id/toolbarr">

        <com.skysoftlk.skyvpnapp.Utils.CustomTxTRegular
            android:id="@+id/name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CPU Cooler"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find heavy apps and cool performance"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/anim_container"
        android:layout_width="0dp"
        android:layout_height="300dp"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_feature_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbarr">

        <com.skyfishjy.library.RippleBackground
            android:id="@+id/content"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="center"
            app:rb_color="@color/accent_teal"
            app:rb_duration="3000"
            app:rb_radius="32dp"
            app:rb_rippleAmount="4"
            app:rb_scale="4">

            <ImageView
                android:id="@+id/centerImage"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_centerInParent="true"
                android:clickable="true" />
        </com.skyfishjy.library.RippleBackground>

        <View
            android:layout_width="246dp"
            android:layout_height="246dp"
            android:layout_gravity="center"
            android:alpha="0.8"
            android:background="@drawable/bg_glow_circle" />

        <ImageView
            android:id="@+id/shadowcpu"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:alpha="0.18"
            android:src="@mipmap/ic_rounded_shadow" />

        <ImageView
            android:id="@+id/cpu"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:padding="45dp"
            android:src="@drawable/ic_cpu_cooling_icon"
            app:tint="@color/accent_teal" />

        <ImageView
            android:id="@+id/scann"
            android:layout_width="232dp"
            android:layout_height="232dp"
            android:layout_gravity="center"
            android:padding="36dp"
            android:src="@drawable/ic_cpu_cooling_redar"
            app:tint="@color/accent_teal" />

        <ImageView
            android:id="@+id/iv_completecheck"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_cooling_complete_check"
            android:visibility="gone"
            app:tint="@color/neon_green" />
    </FrameLayout>

    <com.skysoftlk.skyvpnapp.Utils.CustomTxtSemibold
        android:id="@+id/cpucooler"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_status_pill"
        android:gravity="center"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:text="Scanning Apps..."
        android:textColor="@color/accent_teal"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/anim_container" />

    <RelativeLayout
        android:id="@+id/rel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_glass_card"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cpucooler">

        <ImageView
            android:id="@+id/heart"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.12"
            android:scaleType="centerInside"
            android:src="@drawable/ic_cpu_cooling_redar"
            android:visibility="gone"
            app:tint="@color/accent_teal" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="10dp" />
    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
