<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent"
    android:paddingHorizontal="4dp"
    android:paddingVertical="7dp">

    <RelativeLayout
        android:id="@+id/flag_image_r"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:background="@drawable/bg_server_item"
        android:padding="12dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_flag"
            android:layout_width="54dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/glass_white_border"
            app:strokeWidth="1dp">

            <ImageView
                android:id="@+id/country_flag"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/flag_default"
                app:srcCompat="@drawable/flag_default" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/region_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="12dp"
            android:layout_toStartOf="@id/region_limit"
            android:layout_toEndOf="@id/card_flag"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="DEFAULT REGION"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/region_limit"
            android:layout_width="64dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/server_signal_3"
            android:visibility="visible" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/country_flag1"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <TextView
            android:id="@+id/region_title1"
            android:layout_width="0dp"
            android:layout_height="0dp" />

        <ImageView
            android:id="@+id/region_limit1"
            android:layout_width="0dp"
            android:layout_height="0dp" />
    </LinearLayout>
</RelativeLayout>
