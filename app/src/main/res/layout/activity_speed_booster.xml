<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/coordinator"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ScrollView
                android:id="@+id/main_root_layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="70dp"
                android:background="@drawable/bg_app_gradient"
                android:fillViewport="true"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingTop="18dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="26dp">

                    <RelativeLayout
                        android:id="@+id/toolbar_layout"
                        android:layout_width="match_parent"
                        android:layout_height="64dp">

                        <ImageView
                            android:id="@+id/category"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_glass_card"
                            android:contentDescription="@string/app_name"
                            android:padding="11dp"
                            app:srcCompat="@drawable/ic_menu"
                            app:tint="@color/text_primary" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="14dp"
                            android:layout_toEndOf="@id/category"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Speed Booster"
                                android:textColor="@color/text_primary"
                                android:textSize="22sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Clean memory and keep performance steady"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_feature_header"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingTop="26dp"
                        android:paddingBottom="24dp">

                        <FrameLayout
                            android:id="@+id/rl_main_booster"
                            android:layout_width="260dp"
                            android:layout_height="260dp">

                            <View
                                android:layout_width="250dp"
                                android:layout_height="250dp"
                                android:layout_gravity="center"
                                android:alpha="0.75"
                                android:background="@drawable/bg_glow_circle" />

                            <View
                                android:layout_width="214dp"
                                android:layout_height="214dp"
                                android:layout_gravity="center"
                                android:background="@drawable/bg_connect_ring" />

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:alpha="0.18"
                                android:src="@drawable/meter"
                                app:tint="@color/accent_teal" />

                            <com.hookedonplay.decoviewlib.DecoView
                                android:id="@+id/dynamicArcView2"
                                android:layout_width="204dp"
                                android:layout_height="204dp"
                                android:layout_gravity="center" />

                            <com.hookedonplay.decoviewlib.DecoView
                                android:id="@+id/dynamicArcView3"
                                android:layout_width="204dp"
                                android:layout_height="204dp"
                                android:layout_gravity="center"
                                android:visibility="gone" />

                            <ImageView
                                android:id="@+id/waves"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/top"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Storage"
                                    android:textColor="@color/accent_teal"
                                    android:textSize="12sp"
                                    android:visibility="gone" />

                                <TextView
                                    android:id="@+id/centree"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="100 MB"
                                    android:textColor="@color/text_primary"
                                    android:textSize="30sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/bottom"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_coral_pill"
                                    android:paddingStart="12dp"
                                    android:paddingTop="4dp"
                                    android:paddingEnd="12dp"
                                    android:paddingBottom="4dp"
                                    android:text="Found"
                                    android:textColor="@color/accent_coral"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </FrameLayout>

                        <LinearLayout
                            android:id="@+id/scanlay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_status_pill"
                            android:paddingStart="16dp"
                            android:paddingTop="7dp"
                            android:paddingEnd="16dp"
                            android:paddingBottom="7dp"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/scanning"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Scanning..."
                                android:textColor="@color/accent_teal"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/optimizelay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp">

                            <RelativeLayout
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:background="@drawable/bg_action_circle">

                                <ImageView
                                    android:id="@+id/optbutton"
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:layout_centerInParent="true"
                                    android:src="@drawable/ic_on_off"
                                    app:tint="@color/white" />
                            </RelativeLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="132dp"
                            android:layout_marginEnd="7dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_metric_card"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/processes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="13"
                                android:textColor="@color/text_primary"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Running Processes"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/appsused"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="1.24 GB / "
                                    android:textColor="@color/accent_teal"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/appsfreed"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="2.67 GB"
                                    android:textColor="@color/text_primary"
                                    android:textSize="11sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="132dp"
                            android:layout_marginStart="7dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_metric_card"
                            android:gravity="center_vertical"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/ramperct"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="48%"
                                android:textColor="@color/text_primary"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RAM Usage"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/usedram"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="1.24 GB / "
                                    android:textColor="@color/accent_teal"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/totalram"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="2.67 GB"
                                    android:textColor="@color/text_primary"
                                    android:textSize="11sp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>

            <com.etebarian.meowbottomnavigation.MeowBottomNavigation
                android:id="@+id/bottom_navigation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                app:mbn_backgroundBottomColor="@color/surface_primary"
                app:mbn_circleColor="@color/accent_teal"
                app:mbn_countBackgroundColor="@color/red"
                app:mbn_countTextColor="@color/white"
                app:mbn_defaultIconColor="@color/text_secondary"
                app:mbn_rippleColor="@color/glass_white_border"
                app:mbn_selectedIconColor="@color/white"
                app:mbn_shadowColor="@color/futuristic_bg_end" />
        </androidx.coordinatorlayout.widget.CoordinatorLayout>
    </RelativeLayout>

    <include layout="@layout/drawer_navigation_view" />
</androidx.drawerlayout.widget.DrawerLayout>
