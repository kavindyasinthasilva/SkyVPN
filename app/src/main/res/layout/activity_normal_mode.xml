<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:wheel="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/futuristic_bg_start">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3.5"
        android:gravity="center"
        android:orientation="vertical">

        <com.skysoftlk.skyvpnapp.Utils.CustomTxTRegular
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textAppearance="?android:textAppearanceLarge"
            android:textColor="@color/white"
            android:id="@+id/name"
            android:layout_width="match_parent"
            android:layout_marginTop="20dp"
            android:text="Normal Power Mode"
            android:layout_height="?attr/actionBarSize" />

        <RelativeLayout
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="10dp"
            android:gravity="center">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_glow_circle"
                android:alpha="0.2"/>

            <com.hookedonplay.decoviewlib.DecoView
                android:id="@+id/dynamicArcView2"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                wheel:dv_lineWidth="8dp"
                android:padding="15dp"/>

            <com.skysoftlk.skyvpnapp.Utils.CustomTxTRegular
                android:id="@+id/completion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="25%"
                android:textColor="@color/neon_blue"
                android:textSize="32sp"
                android:textStyle="bold" />
        </RelativeLayout>

    </LinearLayout>

    <LinearLayout
        android:orientation="vertical"
        android:layout_weight="4"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="20dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/glass_white">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="15dp">

                <pl.droidsonroids.gif.GifImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:src="@drawable/l_gif" />

                <LinearLayout
                    android:id="@+id/status_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/item1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="8dp">
                        <ImageView
                            android:id="@+id/istpic"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_grey_dot"
                            app:tint="@color/neon_blue"
                            android:visibility="gone"/>
                        <com.skysoftlk.skyvpnapp.Utils.CustomTxTRegular
                            android:id="@+id/ist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Restoring Brightness..."
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:layout_marginStart="10dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/item2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="8dp">
                        <ImageView
                            android:id="@+id/secpic"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_grey_dot"
                            app:tint="@color/neon_blue"
                            android:visibility="gone"/>
                        <com.skysoftlk.skyvpnapp.Utils.CustomTxTRegular
                            android:id="@+id/sec"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Optimizing Performance..."
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:layout_marginStart="10dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/item3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="8dp">
                        <ImageView
                            android:id="@+id/thipic"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_grey_dot"
                            app:tint="@color/neon_blue"
                            android:visibility="gone"/>
                        <com.skysoftlk.skyvpnapp.Utils.CustomTxTRegular
                            android:id="@+id/thi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reactivating Background Tasks..."
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:layout_marginStart="10dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/item4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="8dp">
                        <ImageView
                            android:id="@+id/foupic"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_grey_dot"
                            app:tint="@color/neon_blue"
                            android:visibility="gone"/>
                        <com.skysoftlk.skyvpnapp.Utils.CustomTxTRegular
                            android:id="@+id/fou"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Normalizing System Services..."
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:layout_marginStart="10dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</LinearLayout>
