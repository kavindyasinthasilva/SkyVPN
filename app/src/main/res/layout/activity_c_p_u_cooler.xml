<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/futuristic_bg_start"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/coordinator"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="100dp">

                    <!-- Toolbar Area -->
                    <RelativeLayout
                        android:id="@+id/toolbar_layout"
                        android:layout_width="match_parent"
                        android:layout_height="?attr/actionBarSize"
                        android:paddingHorizontal="20dp"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/category"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_glass_card"
                            android:padding="8dp"
                            app:srcCompat="@drawable/ic_menu"
                            app:tint="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="@string/cpu_cooler"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <!-- CPU Temp Display -->
                    <FrameLayout
                        android:id="@+id/temp_container"
                        android:layout_width="280dp"
                        android:layout_height="280dp"
                        android:layout_marginTop="30dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/toolbar_layout">

                        <ImageView
                            android:id="@+id/tempimg"
                            android:layout_width="260dp"
                            android:layout_height="260dp"
                            android:layout_gravity="center"
                            android:alpha="0.05"
                            android:background="@drawable/bg_glow_circle" />

                        <RelativeLayout
                            android:layout_width="180dp"
                            android:layout_height="180dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_connect_button"
                            android:elevation="10dp">

                            <ImageView
                                android:id="@+id/iv_tempimg"
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:layout_centerInParent="true"
                                android:src="@drawable/ic_before_cpu_cooler_icon"
                                app:tint="@color/neon_blue" />
                        </RelativeLayout>

                        <!-- Temp Text positioned below but overlapping -->
                        <TextView
                            android:id="@+id/batterytemp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="10dp"
                            android:background="@drawable/bg_glass_card"
                            android:paddingHorizontal="20dp"
                            android:paddingVertical="5dp"
                            android:text="35°C"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <!-- Status Info -->
                    <LinearLayout
                        android:id="@+id/status_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        app:layout_constraintTop_toBottomOf="@id/temp_container">

                        <TextView
                            android:id="@+id/showmain"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/overheated"
                            android:textColor="@color/red"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/showsec"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="@string/apps_are_causing_problem_hit_cool_down"
                            android:textColor="@color/textcolor"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/nooverheating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone" />
                    </LinearLayout>

                    <!-- Apps List (Glass Card) -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/apps_card"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:layout_marginHorizontal="20dp"
                        android:layout_marginTop="25dp"
                        app:cardBackgroundColor="@color/glass_white"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:layout_constraintTop_toBottomOf="@id/status_layout">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recycler_view"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="10dp" />
                    </androidx.cardview.widget.CardView>

                    <!-- Action Button -->
                    <RelativeLayout
                        android:id="@+id/btn_layout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="30dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/apps_card">

                        <ImageView
                            android:id="@+id/coolbutton"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:background="@drawable/bg_connect_button"
                            android:padding="35dp"
                            android:src="@drawable/ic_cpu_cooling_icon"
                            app:tint="@color/neon_blue" />
                    </RelativeLayout>

                    <!-- Ad Space -->
                    <RelativeLayout
                        android:id="@+id/fl_adplaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        app:layout_constraintTop_toBottomOf="@id/btn_layout" />

                    <com.facebook.ads.NativeAdLayout
                        android:id="@+id/native_ad_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:layout_constraintTop_toBottomOf="@id/fl_adplaceholder" />

                    <com.google.android.gms.ads.AdView
                        android:id="@+id/admob_adview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"
                        app:adSize="BANNER"
                        app:adUnitId="@string/banner_ad_unit"
                        app:layout_constraintTop_toBottomOf="@id/native_ad_container" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </ScrollView>

            <!-- Matching Bottom Nav -->
            <com.etebarian.meowbottomnavigation.MeowBottomNavigation
                android:id="@+id/bottom_navigation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                app:mbn_circleColor="@color/neon_blue"
                app:mbn_backgroundBottomColor="@color/futuristic_bg_end"
                app:mbn_countBackgroundColor="@color/red"
                app:mbn_countTextColor="@color/white"
                app:mbn_defaultIconColor="#90a4ae"
                app:mbn_rippleColor="@color/glass_white_border"
                app:mbn_selectedIconColor="@color/white"
                app:mbn_shadowColor="@color/futuristic_bg_end"/>

        </androidx.coordinatorlayout.widget.CoordinatorLayout>
    </RelativeLayout>

    <include
        layout="@layout/drawer_navigation_view" />

</androidx.drawerlayout.widget.DrawerLayout>
