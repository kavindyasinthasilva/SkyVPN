<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/neon_blue">
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="45"
                android:endColor="#1A202C"
                android:startColor="#2D3748"
                android:type="linear" />
            <stroke
                android:width="4dp"
                android:color="@color/glass_white_border" />
            <size
                android:width="150dp"
                android:height="150dp" />
        </shape>
    </item>
</ripple>